{
  "name": "<%= name %>",
  "compatibility_date": "2025-01-01",
  "main": "src/worker/index.ts",
  "vars": {
    "ENVIRONMENT": "local"
  },
  "kv_namespaces": [
    {
      "binding": "CONFIG_KV"
    }
  ],
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  },
  "env": {
    "preview": {
      "vars": {
        "ENVIRONMENT": "staging"
      },
      "kv_namespaces": [
        {
          "binding": "CONFIG_KV",
          "id": "<staging-kv-namespace-id>"
        }
      ],
      "preview_urls": true
    },
    "staging": {
      "vars": {
        "ENVIRONMENT": "staging"
      },
      "kv_namespaces": [
        {
          "binding": "CONFIG_KV",
          "id": "<staging-kv-namespace-id>"
        }
      ]<% if (stagingDomain) { %>,
      "route": {
        "pattern": "<%= stagingDomain %>",
        "custom_domain": true
      }<% } %>
    },
    "production": {
      "vars": {
        "ENVIRONMENT": "production"
      },
      "kv_namespaces": [
        {
          "binding": "CONFIG_KV",
          "id": "<production-kv-namespace-id>"
        }
      ],
      "workers_dev": false<% if (productionDomain) { %>,
      "route": {
        "pattern": "<%= productionDomain %>",
        "custom_domain": true
      }<% } %>
    }
  }
}
