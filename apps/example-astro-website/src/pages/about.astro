---
import { NavBar } from '../components/NavBar';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/index.css';
---

<BaseLayout title="About">
  <NavBar siteName="Example Astro Website" />
  <main class="max-w-2xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold">About</h1>
    <p class="mt-6 text-gray-600 leading-relaxed">
      This site was generated by the <code class="font-mono text-sm bg-gray-100 px-1.5 py-0.5 rounded">astro-cloudflare-app</code>
      Nx generator. It deploys to Cloudflare Workers as pure static assets — no server required, no runtime
      overhead.
    </p>
    <p class="mt-4 text-gray-600 leading-relaxed">
      Pages are pre-rendered at build time with Astro. React components are used for UI and rendered to
      static HTML by default. Add a <code class="font-mono text-sm bg-gray-100 px-1.5 py-0.5 rounded">client:load</code>
      directive to any component to hydrate it in the browser.
    </p>
    <a href="/" class="mt-8 inline-block text-blue-600 hover:text-blue-700 font-medium transition-colors">
      ← Back home
    </a>
  </main>
</BaseLayout>
