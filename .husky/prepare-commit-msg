# Skip cz prompt cleanly in non-interactive sessions (CI, scripted commits,
# Claude Code's Bash tool). cz needs a controlling TTY; if stdin isn't a TTY
# the `exec < /dev/tty` further down prints "Device not configured" noise.
# `/dev/tty` exists as a device file even without a controlling terminal,
# so we test the actual TTY state with `-t 0` (stdin is a TTY).
if [ ! -t 0 ]; then
  exit 0
fi

exec < /dev/tty && npx cz --hook || true
