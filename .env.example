ENVIRONMENT=local
PROJECT_NAME=your-project-name
URL=your-domain.com
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
# Optional: set ONBOARD_AUTO=true for unattended /onboard runs. The skill will
# skip Java install prompt, S3 bucket creation prompt, KV diff confirm,
# static-site URL prompts, and the final push confirmation. You'll still be
# prompted for: Cocogitto bot confirmation, static-site y/n, and per-service y/n.
ONBOARD_AUTO=false
# CLOUDFLARE_API_TOKEN — required permissions: Account/Workers Scripts:Edit,
# Account/Workers KV Storage:Edit, Account/D1:Edit. See README onboarding
# section for the full table including optional Zone-level scopes.
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
