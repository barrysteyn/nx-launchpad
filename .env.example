ENVIRONMENT=local
PROJECT_NAME=your-project-name
URL=your-domain.com
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
# Optional: set ONBOARD_AUTO=true for unattended /onboard runs. The skill will
# skip Java install prompt, S3 bucket creation prompt, KV diff confirm, and
# static-site URL prompts. You'll still be prompted for: Cocogitto bot
# confirmation, static-site y/n, per-service y/n, and (by default) the final
# push at Step 8.3.
ONBOARD_AUTO=false
#
# Optional: set ONBOARD_AUTO_PUSH=true to ALSO auto-push at Step 8.3. Kept
# separate from ONBOARD_AUTO so users with a "don't push without asking" policy
# can still benefit from unattended Steps 1–7.
ONBOARD_AUTO_PUSH=false
# CLOUDFLARE_API_TOKEN — required permissions: Account/Workers Scripts:Edit,
# Account/Workers KV Storage:Edit, Account/D1:Edit. See README onboarding
# section for the full table including optional Zone-level scopes.
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
# NEON_API_KEY — required for the auth service only (Neon Postgres).
# Mint at https://console.neon.tech/app/settings/api-keys
# Free Neon plan is sufficient for staging.
# NEON_API_KEY=your-api-key
