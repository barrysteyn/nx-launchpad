# ------------------------------------------------------------
# Nx / build / generated output
# ------------------------------------------------------------
dist/
tmp/
out/
out-tsc/
coverage/
test-output/

# Nx local cache and workspace metadata
.nx/cache/
.nx/workspace-data/

# Nx graph output
project-graph.html
project-graph.json
nx-graph.html
static/

# ------------------------------------------------------------
# Node / TypeScript
# ------------------------------------------------------------
node_modules/

# TypeScript incremental build metadata
*.tsbuildinfo
tsconfig.tsbuildinfo

# Transpiled JS artifacts in libs (TS source is canonical)
libs/**/*.js
libs/**/*.js.map
libs/**/*.d.ts
libs/**/*.d.ts.map

# Keep intentionally committed Jest config JS files
!libs/**/jest.preset.js
!libs/**/jest.config.js

# ------------------------------------------------------------
# Python / uv
# ------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Generated build artifact — produced by `uv export` before terraform apply
requirements.txt

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Note:
# uv.lock is intentionally NOT ignored.
# It should usually be committed for reproducible environments.

# ------------------------------------------------------------
# Environment / secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example
!.env.staging
!.env.production

# ------------------------------------------------------------
# Vite / Cloudflare
# ------------------------------------------------------------
.vite/
.wrangler/

# Generated resolved config files
config/files/*.resolved.json

# ------------------------------------------------------------
# Terraform
# ------------------------------------------------------------
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/.terraform.tfstate.lock.info
**/terraform.tfvars
**/*.tfvars

# Terraform Lambda build artifacts (generated by tf-apply)
**/builds/

# Note:
# .terraform.lock.hcl is intentionally NOT ignored.
# It should usually be committed for provider version consistency.

# ------------------------------------------------------------
# Java / Rust / generic build dirs
# ------------------------------------------------------------
target/

# ------------------------------------------------------------
# IDEs / editors
# ------------------------------------------------------------
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# VS Code: keep shared repo settings, ignore personal ones
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ------------------------------------------------------------
# Local AI / assistant tooling state
# ------------------------------------------------------------
.claude/*
!.claude/commands/
!.claude/settings.json
docs/superpowers/*

# Uncomment these only if they are truly local-only and should
# never be shared as part of the template repo:
# .cursor/
# .github/instructions/

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
.sass-cache/
connect.lock
libpeerconnection.log
npm-debug.log
pnpm-debug.log
yarn-error.log
testem.log
typings/

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db