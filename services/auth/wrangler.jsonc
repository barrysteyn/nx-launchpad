{
  "name": "auth",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/worker/index.ts",
  "workers_dev": false,
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/.well-known/*"]
  },
  "observability": {
    "enabled": true
  },
  "env": {
    "staging": {
      "name": "auth-staging",
      "vars": {
        "ENVIRONMENT": "staging",
        "BETTER_AUTH_URL": "https://auth.staging.<placeholder-domain>",
        "TRUSTED_ORIGINS": "https://staging.<placeholder-domain>",
        "FROM_EMAIL": "noreply@staging.<placeholder-domain>"
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "<placeholder-hyperdrive-id>"
        }
      ],
      "route": {
        "pattern": "auth.staging.<placeholder-domain>",
        "custom_domain": true
      }
    },
    "production": {
      "name": "auth-production",
      "vars": {
        "ENVIRONMENT": "production",
        "BETTER_AUTH_URL": "https://auth.<placeholder-domain>",
        "TRUSTED_ORIGINS": "https://<placeholder-domain>,https://staging.<placeholder-domain>",
        "FROM_EMAIL": "noreply@<placeholder-domain>"
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "<placeholder-hyperdrive-id>"
        }
      ],
      "route": {
        "pattern": "auth.<placeholder-domain>",
        "custom_domain": true
      }
    }
  }
}
